<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="AMPS.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:AMPS"
    Title="AMPS"
    FlyoutBehavior="Flyout">

    <Shell.FlyoutHeader>
        <Grid Padding="20"
              BackgroundColor="{StaticResource AmpsBlue}">
            <Label Text="AMPS"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />
        </Grid>
    </Shell.FlyoutHeader>

    <FlyoutItem Title="AMPS" Route="Dashboard">
        <ShellContent
            Title="AMPS"
            ContentTemplate="{DataTemplate local:Dashboard}" />
    </FlyoutItem>

    <FlyoutItem Title="Administrar perfiles" Route="ProfileManagement">
        <ShellContent
            Title="Administrar perfiles"
            ContentTemplate="{DataTemplate local:ProfileManagement}" />
    </FlyoutItem>

    <FlyoutItem Title="Matrícula" Route="Matricula">
        <ShellContent
            Title="Matrícula"
            ContentTemplate="{DataTemplate local:Matricula}" />
    </FlyoutItem>

    <FlyoutItem Title="Promedio" Route="Promedio">
        <ShellContent
            Title="Promedio"
            ContentTemplate="{DataTemplate local:Promedio}" />
    </FlyoutItem>

    <FlyoutItem Title="Secuencial" Route="Secuencial">
        <ShellContent
            Title="Secuencial"
            ContentTemplate="{DataTemplate local:Secuencial}" />
    </FlyoutItem>

    <FlyoutItem Title="Settings" Route="SettingsPage">
        <ShellContent
        Title="Settings"
        ContentTemplate="{DataTemplate local:SettingsPage}" />
    </FlyoutItem>

</Shell>