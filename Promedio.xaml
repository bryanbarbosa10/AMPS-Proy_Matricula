<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AMPS.Promedio"
             Title="Calculadora de Promedio">

    <Grid Padding="20" RowDefinitions="Auto,Auto,*">

        <VerticalStackLayout Grid.Row="0" Spacing="8">

            <Label Text="Promedio Acumulado"
                   FontSize="26"
                   FontAttributes="Bold"
                   TextColor="{StaticResource AmpsBlue}"
                   HorizontalOptions="Center"/>

            <Frame Padding="25"
                   CornerRadius="15"
                   BackgroundColor="{AppThemeBinding Light=#E3F2FD, Dark=#1E1E1E}"
                   BorderColor="{StaticResource AmpsBlue}"
                   HasShadow="False"
                   Margin="0,10,0,10">

                <VerticalStackLayout Spacing="5">

                    <Label Text="GPA Actual"
                           FontSize="16"
                           TextColor="{AppThemeBinding Light=Gray, Dark=#BBBBBB}"
                           HorizontalOptions="Center"/>

                    <Label x:Name="LblGpaTotal"
                           Text="0.00"
                           FontSize="52"
                           FontAttributes="Bold"
                           TextColor="{StaticResource AmpsBlue}"
                           HorizontalOptions="Center"/>

                    <Label x:Name="LblCreditsTotal"
                           Text="Créditos completados: 0"
                           FontSize="14"
                           TextColor="{AppThemeBinding Light=Gray, Dark=#BBBBBB}"
                           HorizontalOptions="Center"/>

                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>

        <VerticalStackLayout Grid.Row="1" Spacing="5" Margin="0,5,0,10">

            <Label Text="Notas registradas"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="{StaticResource AmpsBlue}" />

            <CollectionView x:Name="GradesCollectionView"
                            ItemsSource="{Binding MisNotas}"
                            HeightRequest="180">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Padding="12"
                               Margin="0,5"
                               CornerRadius="8"
                               BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#444444}"
                               BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                               HasShadow="False">

                            <Grid ColumnDefinitions="*,Auto">

                                <VerticalStackLayout Grid.Column="0">
                                    <Label Text="{Binding Materia}"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                                    <Label Text="{Binding Creditos, StringFormat='{0} créditos'}"
                                           FontSize="12"
                                           TextColor="{AppThemeBinding Light=Gray, Dark=#BBBBBB}" />
                                </VerticalStackLayout>

                                <Label Grid.Column="1"
                                       Text="{Binding Calificacion}"
                                       FontSize="22"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource AmpsBlue}"
                                       VerticalOptions="Center" />

                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>

        <VerticalStackLayout Grid.Row="2" Spacing="5">

            <Label Text="GPA anteriores"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="{StaticResource AmpsBlue}" />

            <CollectionView x:Name="GpaHistoryCollectionView"
                            ItemsSource="{Binding HistorialGpa}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Padding="12"
                               Margin="0,5"
                               CornerRadius="8"
                               BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#444444}"
                               BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                               HasShadow="False">

                            <VerticalStackLayout Spacing="4">

                                <Label Text="{Binding NewGpa, StringFormat='GPA actualizado: {0:F2}'}"
                                       FontSize="17"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource AmpsBlue}" />

                                <Label Text="{Binding PreviousGpa, StringFormat='Promedio anterior: {0:F2}'}"
                                       FontSize="13"
                                       TextColor="{AppThemeBinding Light=Gray, Dark=#BBBBBB}" />

                                <Label Text="{Binding AddedCourseName, StringFormat='Clase añadida: {0}'}"
                                       FontSize="13"
                                       TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                                <Label Text="{Binding AddedCourseCode, StringFormat='Código: {0}'}"
                                       FontSize="12"
                                       TextColor="{AppThemeBinding Light=Gray, Dark=#BBBBBB}" />

                                <Label Text="{Binding GradeLetter, StringFormat='Nota: {0}'}"
                                       FontSize="12"
                                       TextColor="{StaticResource AmpsBlue}" />

                                <Label Text="{Binding DateSaved, StringFormat='Fecha: {0:MM/dd/yyyy}'}"
                                       FontSize="11"
                                       TextColor="{AppThemeBinding Light=Gray, Dark=#BBBBBB}" />

                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>

    </Grid>
</ContentPage>