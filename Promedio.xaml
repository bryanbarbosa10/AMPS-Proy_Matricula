<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AMPS.Promedio"
             Title="Promedio">

    <Grid Padding="20"
          RowDefinitions="Auto,*,Auto">

        <!-- GPA principal más compacto -->
        <VerticalStackLayout Grid.Row="0"
                             Spacing="6"
                             Margin="0,0,0,8">

            <Label Text="Promedio Acumulado"
                   FontSize="26"
                   FontAttributes="Bold"
                   TextColor="{StaticResource AmpsBlue}"
                   HorizontalOptions="Center"/>

            <Frame Padding="14"
                   CornerRadius="18"
                   BackgroundColor="{AppThemeBinding Light=#E3F2FD, Dark=#1E1E1E}"
                   BorderColor="{StaticResource AmpsBlue}"
                   HasShadow="False"
                   Margin="0,5,0,5">

                <VerticalStackLayout Spacing="2"
                                     HorizontalOptions="Center">

                    <Label Text="GPA Actual"
                           FontSize="14"
                           TextColor="{AppThemeBinding Light=Gray, Dark=#BBBBBB}"
                           HorizontalOptions="Center"/>

                    <Label x:Name="LblGpaTotal"
                           Text="0.00"
                           FontSize="54"
                           FontAttributes="Bold"
                           TextColor="{StaticResource AmpsBlue}"
                           HorizontalOptions="Center"/>

                    <Label x:Name="LblCreditsTotal"
                           Text="Créditos completados: 0"
                           FontSize="14"
                           TextColor="{AppThemeBinding Light=Gray, Dark=#BBBBBB}"
                           HorizontalOptions="Center"/>

                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>


        <!-- Notas registradas: sección principal con scroll -->
        <Grid Grid.Row="1"
              RowDefinitions="Auto,*"
              Margin="0,4,0,10">

            <Label Grid.Row="0"
                   Text="Notas registradas"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="{StaticResource AmpsBlue}"
                   Margin="0,0,0,6" />

            <Frame Grid.Row="1"
                   Padding="8"
                   CornerRadius="10"
                   HasShadow="False"
                   BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#444444}"
                   BackgroundColor="{AppThemeBinding Light=#FAFAFA, Dark=#151515}">

                <CollectionView x:Name="GradesCollectionView"
                                ItemsSource="{Binding MisNotas}"
                                VerticalOptions="FillAndExpand">

                    <CollectionView.EmptyView>
                        <Label Text="Todavía no hay notas registradas."
                               TextColor="Gray"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               Margin="0,20"/>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Padding="12"
                                   Margin="0,5"
                                   CornerRadius="8"
                                   BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#444444}"
                                   BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                                   HasShadow="False">

                                <Grid ColumnDefinitions="*,Auto">

                                    <VerticalStackLayout Grid.Column="0"
                                                         Spacing="2">

                                        <Label Text="{Binding Materia}"
                                               FontSize="17"
                                               FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                                        <Label Text="{Binding Creditos, StringFormat='{0} créditos'}"
                                               FontSize="13"
                                               TextColor="{AppThemeBinding Light=Gray, Dark=#BBBBBB}" />

                                    </VerticalStackLayout>

                                    <Label Grid.Column="1"
                                           Text="{Binding Calificacion}"
                                           FontSize="28"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource AmpsBlue}"
                                           VerticalOptions="Center"
                                           Margin="15,0,5,0" />

                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </Frame>
        </Grid>


        <!-- Historial GPA compacto, side by side -->
        <VerticalStackLayout Grid.Row="2"
                             Spacing="5"
                             Margin="0,0,0,0">

            <Label Text="GPA anteriores"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="{StaticResource AmpsBlue}" />

            <CollectionView x:Name="GpaHistoryCollectionView"
                            ItemsSource="{Binding HistorialGpa}"
                            HeightRequest="230">

                <CollectionView.EmptyView>
                    <Label Text="Todavía no hay historial de GPA."
                           TextColor="Gray"
                           HorizontalOptions="Center"
                           Margin="0,20"/>
                </CollectionView.EmptyView>

                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical"
                                     Span="2"
                                     HorizontalItemSpacing="10"
                                     VerticalItemSpacing="10" />
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Padding="12"
                               Margin="0,5"
                               CornerRadius="8"
                               BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#444444}"
                               BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                               HasShadow="False">

                            <VerticalStackLayout Spacing="4">

                                <Label Text="{Binding NewGpa, StringFormat='GPA actualizado: {0:F2}'}"
                                       FontSize="17"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource AmpsBlue}" />

                                <Label Text="{Binding PreviousGpa, StringFormat='Promedio anterior: {0:F2}'}"
                                       FontSize="13"
                                       TextColor="{AppThemeBinding Light=Gray, Dark=#BBBBBB}" />

                                <Label Text="{Binding TotalCreditsAdded, StringFormat='Créditos añadidos: {0}'}"
                                       FontSize="12"
                                       TextColor="{AppThemeBinding Light=Gray, Dark=#BBBBBB}" />

                                <Label Text="Clases añadidas:"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                                <Label Text="{Binding AddedCoursesSummary}"
                                       FontSize="11"
                                       LineBreakMode="WordWrap"
                                       MaxLines="5"
                                       TextColor="{AppThemeBinding Light=Black, Dark=White}" />

                                <Label Text="{Binding DateSaved, StringFormat='Fecha: {0:MM/dd/yyyy}'}"
                                       FontSize="11"
                                       TextColor="{AppThemeBinding Light=Gray, Dark=#BBBBBB}" />

                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>

    </Grid>
</ContentPage>